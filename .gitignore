.gitignore
# виртуальное окружение
venv/
__pycache__/
*.pyc
*.pyo

# переменные окружения
.env
cookies.txt
cookies.json

# системные файлы
.DS_Store

# логи
*.log

# временные файлы скачивания
downloads/

# IDE
.idea/
.vscode/
*.swp

# Dolt database files (added by bd init)
.dolt/
.beads/
*.db

# Markdown не отслеживаем (кроме README.md)
AGENTS.md
PROJECT_LOG.md
DEPLOY.md

# тестовые скрипты
test_local.py

# alembic (если не нужно отслеживать)
# alembic/versions/*.py
