# ==================== ОБЯЗАТЕЛЬНЫЕ ====================

# Токен бота (получить у @BotFather)
BOT_TOKEN=

# Telegram API (получить на https://my.telegram.org)
# нужны для Local Bot API (контейнер bot-api)
API_ID=
API_HASH=

# Юзернейм бота (без @) — используется в подписи к медиа
BOT_USERNAME=your_bot_username

# ==================== БАЗА ДАННЫХ ====================

DB_HOST=postgres
DB_PORT=5432
DB_NAME=bot_4_youtube
DB_USER=bot_4_youtube
DB_PASSWORD=

# ==================== АДМИНЫ ====================

# Telegram ID админов через запятую (получат алерты о падении источников)
ADMIN_IDS=
ADMIN_USERNAME=admin

# ==================== ПРОКСИ ====================

# Резидентный SOCKS5 прокси (primary источник скачивания)
# Формат: socks5://user:pass@host:port  или  socks5://host:port
PROXY_URL=socks5://31.133.93.112:1080

# ==================== ЛИМИТЫ И КЭШ ====================

# Кэш скачиваний в БД (дни) — не перекачиваем одно и то же видео
CACHE_TTL_DAYS=1

# ==================== БАЛАНСИРОВКА ПРОКСИ/WARP ====================

# Порог размера для маршрутизации (МБ):
# видео < порога → через WARP (разгружаем прокси от мелких файлов)
# видео ≥ порога → через прокси (быстрый путь для HD)
SMALL_VIDEO_THRESHOLD_MB=30

# Префлайт-фильтр: качества с оценкой > этого порога не показываются юзеру
# (оценка yt-dlp обычно завышена, 2300 даёт запас ~15% от реального 2 ГБ лимита)
MAX_QUALITY_SIZE_MB=2300
